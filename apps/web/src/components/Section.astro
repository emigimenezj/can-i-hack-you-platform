---
interface Props {
	id?: string;
	eyebrow?: string;
	title: string;
	description?: string;
}

const { id, eyebrow, title, description } = Astro.props;
const hasTitleSlot = Astro.slots.has("title");
---

<section id={id} class="section-block">
	<div class="container">
		{eyebrow && <p class="eyebrow">{eyebrow}</p>}
		<h2 class:list={[hasTitleSlot && "section-title-mixed"]}>
			<slot name="title">{title}</slot>
		</h2>
		{description && <p class="section-description">{description}</p>}
		<div class="section-content">
			<slot />
		</div>
	</div>
</section>